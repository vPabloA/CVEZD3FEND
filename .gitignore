.venv/
__pycache__/
*.pyc
.pytest_cache/
.env
data/raw/sources/*
!data/raw/sources/.gitkeep
data/raw/reference/*
!data/raw/reference/.gitkeep
data/cache/*
!data/cache/.gitkeep
data/review/*
!data/review/.gitkeep
node_modules/
web/dist/
web/public/data/*
!web/public/data/.gitkeep
.DS_Store
*.egg-info/
dist/
build/
# `dist/` (above) also matches data/dist/ -- the built static knowledge bundle
# is the static-first deliverable and ships with the repo, so re-include it.
!data/dist/
!data/dist/**

# TS project-reference build artifacts (generated by `tsc -b`)
web/*.tsbuildinfo
web/vite.config.js
web/vite.config.d.ts
