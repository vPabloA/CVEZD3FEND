# Copy to .env and adjust as needed. Never commit a real .env.

# --- Paths ---
CVEZD3FEND_DATA_DIR=data

# --- Build window ---
# ISO date (YYYY-MM-DD) used to choose CVE years (current + previous). Defaults to "today".
# CVEZD3FEND_REFERENCE_DATE=2026-06-09

# Cap CVE records processed per year (0 = unlimited). Keeps the static bundle small.
CVEZD3FEND_MAX_CVES_PER_YEAR=200

# Max ranked routes emitted per CVE
CVEZD3FEND_TOP_ROUTES_PER_CVE=3

# Cap first-class gap (+ CTEM action) nodes emitted per gap reason. True totals
# are still reported in quality-report.json (no silent truncation).
CVEZD3FEND_MAX_GAPS_PER_REASON=50

# Cap canonical CWE->D3FEND framework routes (used by the Coverage view).
CVEZD3FEND_MAX_FRAMEWORK_ROUTES=1000

# --- HTTP fetch limits ---
CVEZD3FEND_HTTP_TIMEOUT_SECONDS=30
CVEZD3FEND_HTTP_MAX_BYTES=26214400

# --- Optional collectors ---
CVEZD3FEND_ENABLE_KEV=false
CVEZD3FEND_ENABLE_EPSS=false

# --- AI / Intelligence layer (all optional, offline by default) ---
CVEZD3FEND_AI_ENABLED=false
CVEZD3FEND_AI_PROVIDER=mock
# CVEZD3FEND_AI_MODEL=
# Provider API keys (never commit real values):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1

CVEZD3FEND_RAG_VECTOR_STORE=false

# --- Optional API sidecar ---
CVEZD3FEND_API_HOST=127.0.0.1
CVEZD3FEND_API_PORT=8000

# --- Static serve ---
CVEZD3FEND_SERVE_PORT=8787
